{
  "name": "archivverwalter",
  "version": "1.2.40",
  "description": "Archive manager — index, deduplicate and browse file archives via web UI",
  "main": "electron/main.js",
  "author": {
    "name": "4CPA — Forecasting Press Association",
    "email": "admin@4cpa.ch",
    "url": "https://github.com/4cpa"
  },
  "license": "MIT",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:rebuild": "electron-builder install-app-deps",
    "dist": "npm run electron:rebuild && electron-builder --win --mac --linux --publish=never",
    "dist:win": "npm run dist:win10 && npm run dist:win11",
    "dist:win10": "electron-builder install-app-deps --arch x64 && electron-builder --win --config build/win10.js --publish=never",
    "dist:win11": "npm run dist:win11:x64 && npm run dist:win11:arm64",
    "dist:win11:x64": "electron-builder install-app-deps --arch x64 && electron-builder --win --config build/win11.js --x64 --publish=never",
    "dist:win11:arm64": "electron-builder install-app-deps --arch arm64 && electron-builder --win --config build/win11.js --arm64 --publish=never",
    "dist:mac": "npm run electron:rebuild && electron-builder --mac --publish=never",
    "dist:linux": "electron-builder install-app-deps --arch x64 && electron-builder --linux --publish=never",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "preversion": "npm test",
    "version": "node scripts/changelog-stamp.js && git add CHANGELOG.md public/i18n.js",
    "postversion": "git push",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\""
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "resetModules": false
  },
  "build": {
    "appId": "ch.archivverwalter.app",
    "productName": "ArchivVerwalter",
    "copyright": "Copyright © 2026",
    "compression": "normal",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "electron/icons"
    },
    "files": [
      "electron/main.js",
      "src/**/*",
      "index.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArchivVerwalter",
      "runAfterFinish": false,
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "synopsis": "Archive manager — index, deduplicate and browse file archives"
    }
  }
}
